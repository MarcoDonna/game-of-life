<h1>GameFrames#show</h1>
<p>Find me in app/views/game_frames/show.html.erb</p>

<%= link_to "All games", games_url %>

<h3>
  The Game of Life in a <%= @frame.game.board_width %> x <%= @frame.game.board_height %> board.
</h3>
<h5>
  Game created by <%= @game.user.email %>.
</h5>

<%= turbo_frame_tag "frame-tag" do %>
    <%= render @frame %>
<% end %>


<%= link_to "Destroy game", destroy_game_url(@game), data: {turbo_method: :delete, turbo_confirm: "Are you sure?"} if @game.user == current_user %>

<%= render "games/users_with_access" %>